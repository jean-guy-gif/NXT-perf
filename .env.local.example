# Supabase project credentials (get from https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# NXT Vocal - Transcription (Groq Whisper gratuit)
GROQ_API_KEY=gsk_...

# NXT Vocal - Extraction LLM (Claude via OpenRouter)
OPENROUTER_API_KEY=sk-or-v1-...

# Coach RAG (Sous-PR Coach-0)
# Voyage AI embeddings — create key at https://voyageai.com
VOYAGE_API_KEY=pa-...
# Optional : embedding model + default chat model
# VOYAGE_MODEL=voyage-2
# COACH_RAG_DEFAULT_MODEL=anthropic/claude-sonnet-4-5
