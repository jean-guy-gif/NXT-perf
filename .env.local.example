# Supabase project credentials (get from https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# NXT Vocal - Transcription (Groq Whisper gratuit)
GROQ_API_KEY=gsk_...

# NXT Vocal - Extraction LLM (Claude via OpenRouter)
OPENROUTER_API_KEY=sk-or-v1-...

# Coach RAG (Sous-PR Coach-0)
# Embeddings + chat via OpenRouter (clé déjà configurée ci-dessus).
# OpenRouter proxifie /v1/embeddings (openai/text-embedding-3-small, 1536 dims).
# Optional : override embedding model + default chat model
# OPENAI_EMBED_MODEL=openai/text-embedding-3-small
# COACH_RAG_DEFAULT_MODEL=anthropic/claude-sonnet-4-5
